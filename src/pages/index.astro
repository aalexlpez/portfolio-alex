---
import { Image, Picture } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import { portfolio } from "../data/portfolio";
import allRemoveBgImage from "../assets/www.allremovebg.com.png";
import findPersonsImage from "../assets/www.find-persons.com.png";
import profileImage from "../assets/photo-profile.jpeg";

const projectImages = {
  findPersons: findPersonsImage,
  allRemoveBg: allRemoveBgImage,
} as const;
---

<Layout>
  <main id="top" class="section-shell pb-28 md:pb-16">
    <section class="px-4 pb-16 pt-28 md:px-6 md:pb-24 md:pt-36">
      <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[1.25fr_0.75fr] lg:items-center">
        <div class="space-y-8" data-reveal>
          <span class="eyebrow">{portfolio.hero.eyebrow}</span>

          <div class="space-y-6">
            <p class="font-mono text-sm uppercase tracking-[0.22em] text-cyan-200/75">
              {portfolio.role} - {portfolio.location}
            </p>
            <h1 class="section-title max-w-4xl text-4xl font-semibold leading-tight sm:text-5xl lg:text-7xl">
              {portfolio.hero.headline}
            </h1>
            <p class="section-copy max-w-3xl text-base leading-8 sm:text-lg">
              {portfolio.hero.summary}
            </p>
          </div>

          <div class="flex flex-wrap gap-3">
            <a
              href="#contact"
              data-scroll-link
              class="button-primary px-6 py-3 text-sm font-semibold sm:px-7 sm:text-base"
            >
              {portfolio.hero.primaryCta}
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.8"
                  d="M4 6h16M4 6l8 6 8-6M4 6v12h16V6"
                ></path>
              </svg>
            </a>
            <a
              href={portfolio.cvPath}
              download
              class="button-secondary px-6 py-3 text-sm font-semibold sm:px-7 sm:text-base"
            >
              {portfolio.hero.secondaryCta}
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.8"
                  d="M12 5v9m0 0 4-4m-4 4-4-4m-3 8h14"
                ></path>
              </svg>
            </a>
          </div>

          <div class="flex flex-wrap items-center gap-3 text-sm text-white/72">
            <a
              href={portfolio.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-full border border-white/10 bg-white/4 px-4 py-2 transition duration-300 hover:border-white/20 hover:bg-white/8"
            >
              Ver LinkedIn
            </a>
            <button
              type="button"
              data-copy-text={portfolio.email}
              class="relative rounded-full border border-white/10 bg-white/4 px-4 py-2 transition duration-300 hover:border-white/20 hover:bg-white/8"
            >
              Copiar email
              <span
                data-copy-feedback
                class="copy-feedback pointer-events-none absolute left-1/2 top-[-2.5rem] -translate-x-1/2 rounded-full border border-emerald-300/20 bg-emerald-400/12 px-3 py-1 text-xs text-emerald-100 opacity-0"
              >
                Email copiado
              </span>
            </button>
          </div>
        </div>

        <aside
          class="section-surface relative overflow-hidden rounded-[2rem] p-6 md:p-8"
          data-reveal
          style="--reveal-delay: 120ms;"
        >
          <div class="absolute inset-x-0 top-0 h-28 bg-gradient-to-b from-cyan-300/8 to-transparent"></div>
          <div class="relative space-y-6">
            <div class="flex items-center gap-4">
              <Picture
                src={profileImage}
                alt={portfolio.name}
                widths={[128, 192, 256]}
                sizes="(max-width: 768px) 96px, 144px"
                formats={["webp", "avif"]}
                quality={92}
                class="h-20 w-20 rounded-[1.4rem] border border-white/12 object-cover shadow-[0_18px_40px_rgba(3,8,20,0.35)] md:h-28 md:w-28"
              />
              <div class="space-y-2">
                <p class="text-2xl font-semibold tracking-[-0.04em] text-white">{portfolio.name}</p>
                <p class="text-sm text-white/72">{portfolio.roleSecondary}</p>
                <div class="inline-flex items-center gap-2 rounded-full border border-emerald-300/20 bg-emerald-400/10 px-3 py-1 font-mono text-xs text-emerald-100">
                  <span class="h-2 w-2 rounded-full bg-emerald-300 shadow-[0_0_12px_rgba(74,222,128,0.7)]"></span>
                  {portfolio.availability}
                </div>
              </div>
            </div>

            <div class="grid gap-3 sm:grid-cols-2">
              <div class="rounded-[1.35rem] border border-white/8 bg-white/[0.03] p-4">
                <p class="font-mono text-xs uppercase tracking-[0.18em] text-white/42">Ubicación</p>
                <p class="mt-3 text-sm text-white/82">{portfolio.location}</p>
              </div>
              <div class="rounded-[1.35rem] border border-white/8 bg-white/[0.03] p-4">
                <p class="font-mono text-xs uppercase tracking-[0.18em] text-white/42">Disponibilidad</p>
                <p class="mt-3 text-sm text-white/82">{portfolio.workModel}</p>
              </div>
              <div class="rounded-[1.35rem] border border-white/8 bg-white/[0.03] p-4 sm:col-span-2">
                <p class="font-mono text-xs uppercase tracking-[0.18em] text-white/42">Señal de confianza</p>
                <p class="mt-3 text-sm leading-7 text-white/82">
                  Perfil acostumbrado a producto digital, entornos corporativos y soporte a negocio.
                </p>
              </div>
            </div>

            <div class="rounded-[1.5rem] border border-white/8 bg-[linear-gradient(135deg,rgba(34,211,238,0.08),rgba(139,92,246,0.08))] p-5">
              <p class="font-mono text-xs uppercase tracking-[0.18em] text-white/44">Qué te llevas si me contactas</p>
              <ul class="mt-4 space-y-3 text-sm leading-7 text-white/82">
                <li>Frontend moderno con foco en claridad, rendimiento y conversión.</li>
                <li>Capacidad para integrarme con backend, datos y despliegue.</li>
                <li>Comunicación técnica cercana a negocio y continuidad en producción.</li>
              </ul>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section id="value" class="px-4 py-8 md:px-6 md:py-12">
      <div class="mx-auto max-w-6xl">
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
          {
            portfolio.metrics.map((metric, index) => (
              <article
                class="section-surface rounded-[1.75rem] p-5"
                data-reveal
                style={`--reveal-delay: ${index * 80}ms;`}
              >
                <p class="font-mono text-xs uppercase tracking-[0.18em] text-white/42">Señal clave</p>
                <p class="mt-5 text-2xl font-semibold tracking-[-0.04em] text-white">{metric.value}</p>
                <p class="mt-3 text-sm leading-7 text-white/72">{metric.label}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="px-4 py-18 md:px-6 md:py-24">
      <div class="mx-auto max-w-6xl space-y-10">
        <div class="max-w-3xl space-y-4" data-reveal>
          <p class="section-kicker">Enfoque profesional</p>
          <h2 class="section-title text-3xl font-semibold sm:text-4xl">Un perfil técnico que ayuda a producto, negocio y entrega.</h2>
          <p class="section-copy text-base leading-8 sm:text-lg">
            Mi propuesta no es sólo saber usar un framework. Aporto criterio para construir interfaces que se entienden, se sienten profesionales y pueden sostenerse con backend, datos y despliegues reales.
          </p>
        </div>

        <div class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
          <div class="grid gap-5">
            {
              portfolio.capabilityGroups.map((group, index) => (
                <article
                  class="section-surface rounded-[1.8rem] p-6"
                  data-reveal
                  style={`--reveal-delay: ${index * 90}ms;`}
                >
                  <p class="font-mono text-xs uppercase tracking-[0.18em] text-cyan-200/76">{group.title}</p>
                  <p class="mt-4 text-sm leading-7 text-white/72">{group.description}</p>
                  <div class="mt-5 flex flex-wrap gap-2.5">
                    {
                      group.items.map((item) => (
                        <span class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-2 font-mono text-xs text-white/84">
                          {item}
                        </span>
                      ))
                    }
                  </div>
                </article>
              ))
            }
          </div>

          <div class="grid gap-5">
            {
              portfolio.differentiators.map((item, index) => (
                <article
                  class="section-surface rounded-[1.8rem] p-6"
                  data-reveal
                  style={`--reveal-delay: ${120 + index * 90}ms;`}
                >
                  <p class="text-lg font-semibold tracking-[-0.03em] text-white">{item.title}</p>
                  <p class="mt-3 text-sm leading-7 text-white/72">{item.description}</p>
                </article>
              ))
            }
          </div>
        </div>

        <div class="section-surface rounded-[2rem] p-6 md:p-8" data-reveal>
          <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
            <div class="max-w-2xl">
              <p class="section-kicker">Credenciales rápidas</p>
              <h3 class="mt-3 text-2xl font-semibold tracking-[-0.04em] text-white">Detalles que ayudan a reducir dudas al contratar.</h3>
            </div>
            <div class="flex flex-wrap gap-3">
              {
                portfolio.credentials.map((item) => (
                  <span class="rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm text-white/80">
                    {item}
                  </span>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="experience" class="px-4 py-18 md:px-6 md:py-24">
      <div class="mx-auto max-w-6xl space-y-10">
        <div class="max-w-3xl space-y-4" data-reveal>
          <p class="section-kicker">Experiencia</p>
          <h2 class="section-title text-3xl font-semibold sm:text-4xl">Experiencia alineada con producto web, operaciones y continuidad.</h2>
          <p class="section-copy text-base leading-8 sm:text-lg">
            He trabajado en contextos distintos, pero con algo en común: soluciones que debían funcionar bien, integrarse con otros equipos y sostenerse en entornos reales.
          </p>
        </div>

        <div class="grid gap-5">
          {
            portfolio.experience.map((job, index) => (
              <article
                class="section-surface rounded-[2rem] p-6 md:p-8"
                data-reveal
                style={`--reveal-delay: ${index * 90}ms;`}
              >
                <div class="grid gap-6 lg:grid-cols-[0.34fr_1fr]">
                  <div class="space-y-3">
                    <p class="font-mono text-xs uppercase tracking-[0.18em] text-cyan-200/76">{job.period}</p>
                    <div>
                      <h3 class="text-xl font-semibold tracking-[-0.03em] text-white">{job.title}</h3>
                      <p class="mt-1 text-sm text-white/72">{job.company}</p>
                      <p class="mt-2 text-sm text-white/48">{job.location}</p>
                    </div>
                  </div>

                  <div class="space-y-5">
                    <p class="text-sm leading-7 text-white/78">{job.summary}</p>
                    <ul class="grid gap-3 md:grid-cols-3">
                      {
                        job.highlights.map((highlight) => (
                          <li class="rounded-[1.4rem] border border-white/8 bg-white/[0.03] p-4 text-sm leading-7 text-white/72">
                            {highlight}
                          </li>
                        ))
                      }
                    </ul>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="projects" class="px-4 py-18 md:px-6 md:py-24">
      <div class="mx-auto max-w-6xl space-y-10">
        <div class="max-w-3xl space-y-4" data-reveal>
          <p class="section-kicker">Proyectos destacados</p>
          <h2 class="section-title text-3xl font-semibold sm:text-4xl">Casos que muestran producto, implementación y criterio técnico.</h2>
          <p class="section-copy text-base leading-8 sm:text-lg">
            Seleccioné proyectos que ayudan a entender cómo trabajo cuando hay que conectar diseño, experiencia, tecnología y resultados.
          </p>
        </div>

        <div class="grid gap-8">
          {
            portfolio.projects.map((project, index) => (
              <article
                class="section-surface overflow-hidden rounded-[2.2rem]"
                data-reveal
                style={`--reveal-delay: ${index * 120}ms;`}
              >
                <div class="grid lg:grid-cols-[1.05fr_0.95fr]">
                  <div class="relative min-h-[320px] overflow-hidden border-b border-white/8 bg-[linear-gradient(135deg,rgba(34,211,238,0.09),rgba(124,58,237,0.18))] lg:border-b-0 lg:border-r">
                    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.14),transparent_55%)]"></div>
                    <div class="relative h-full p-6 md:p-8">
                      <div class="mx-auto h-full max-w-[38rem] rounded-[1.6rem] border border-white/10 bg-[#08101b] p-3 shadow-[0_30px_60px_rgba(2,8,20,0.42)]">
                        <div class="mb-3 flex items-center gap-2 border-b border-white/10 pb-3">
                          <span class="h-3 w-3 rounded-full bg-rose-400"></span>
                          <span class="h-3 w-3 rounded-full bg-amber-300"></span>
                          <span class="h-3 w-3 rounded-full bg-emerald-400"></span>
                          <span class="ml-3 rounded-full bg-white/6 px-3 py-1 font-mono text-[11px] text-white/52">
                            {project.url}
                          </span>
                        </div>
                        <Image
                          src={projectImages[project.imageKey]}
                          alt={project.title}
                          width={1200}
                          quality={92}
                          format="webp"
                          class="h-[240px] w-full rounded-[1rem] object-cover object-top md:h-[320px]"
                        />
                      </div>
                    </div>
                  </div>

                  <div class="flex flex-col justify-between p-6 md:p-8">
                    <div class="space-y-5">
                      <div>
                        <p class="font-mono text-xs uppercase tracking-[0.18em] text-cyan-200/76">{project.subtitle}</p>
                        <h3 class="mt-3 text-2xl font-semibold tracking-[-0.04em] text-white">{project.title}</h3>
                      </div>

                      <div class="flex flex-wrap gap-2.5">
                        {
                          project.stack.map((item) => (
                            <span class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-2 font-mono text-xs text-white/82">
                              {item}
                            </span>
                          ))
                        }
                      </div>

                      <p class="text-sm leading-7 text-white/76">{project.summary}</p>
                      <p class="rounded-[1.5rem] border border-cyan-300/12 bg-cyan-300/[0.06] p-4 text-sm leading-7 text-white/78">
                        {project.impact}
                      </p>
                    </div>

                    <div class="mt-6 flex flex-wrap gap-3">
                      <a
                        href={project.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="button-primary px-5 py-3 text-sm font-semibold"
                      >
                        Ver proyecto
                      </a>
                    </div>
                  </div>
                </div>
              </article>
            ))
          }
        </div>

        <article class="section-surface rounded-[2.2rem] p-6 md:p-8" data-reveal>
          <div class="grid gap-8 lg:grid-cols-[0.75fr_1.25fr] lg:items-start">
            <div class="space-y-4">
              <p class="section-kicker">Trabajo confidencial</p>
              <h3 class="text-2xl font-semibold tracking-[-0.04em] text-white">Experiencia enterprise que no depende de tener todo público.</h3>
              <p class="text-sm leading-7 text-white/72">
                Parte de mi recorrido está en productos internos y entornos regulados. Aunque no todo pueda mostrarse visualmente, sí demuestra solidez en mantenimiento, evolución y coordinación técnica.
              </p>
            </div>

            <div class="grid gap-4 md:grid-cols-3">
              {
                portfolio.enterpriseHighlights.map((item) => (
                  <article class="rounded-[1.6rem] border border-white/8 bg-white/[0.03] p-5">
                    <h4 class="text-lg font-semibold tracking-[-0.03em] text-white">{item.title}</h4>
                    <p class="mt-3 text-sm leading-7 text-white/70">{item.description}</p>
                    <div class="mt-4 flex flex-wrap gap-2">
                      {
                        item.tags.map((tag) => (
                          <span class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-2 font-mono text-[11px] text-white/82">
                            {tag}
                          </span>
                        ))
                      }
                    </div>
                  </article>
                ))
              }
            </div>
          </div>
        </article>
      </div>
    </section>

    <section id="contact" class="px-4 pb-20 pt-18 md:px-6 md:pb-24 md:pt-24">
      <div class="mx-auto max-w-6xl">
        <article class="section-surface overflow-hidden rounded-[2.4rem] p-6 md:p-8 lg:p-10" data-reveal>
          <div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
            <div class="space-y-5">
              <p class="section-kicker">Contacto</p>
              <h2 class="section-title text-3xl font-semibold sm:text-4xl">Si encaja lo que buscas, hablemos.</h2>
              <p class="section-copy text-base leading-8 sm:text-lg">
                Estoy abierto a oportunidades donde pueda aportar valor en frontend de producto, evolución de aplicaciones web o perfiles híbridos con respaldo fullstack.
              </p>
              <div class="space-y-3 text-sm text-white/74">
                <p>
                  <span class="font-mono text-white/44">Email:</span>
                  <a href={`mailto:${portfolio.email}`} class="ml-2 text-white transition duration-300 hover:text-cyan-200">
                    {portfolio.email}
                  </a>
                </p>
                <p>
                  <span class="font-mono text-white/44">Teléfono:</span>
                  <a href={portfolio.phoneHref} class="ml-2 text-white transition duration-300 hover:text-cyan-200">
                    {portfolio.phoneDisplay}
                  </a>
                </p>
                <p>
                  <span class="font-mono text-white/44">LinkedIn:</span>
                  <a
                    href={portfolio.linkedin}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="ml-2 text-white transition duration-300 hover:text-cyan-200"
                  >
                    {portfolio.linkedinLabel}
                  </a>
                </p>
              </div>
            </div>

            <div class="grid gap-4 md:grid-cols-2">
              <button
                type="button"
                data-email-action
                data-email-to={portfolio.email}
                class="relative rounded-[1.7rem] border border-white/10 bg-white/[0.04] p-5 text-left transition duration-300 hover:border-cyan-300/30 hover:bg-white/[0.06]"
              >
                <p class="font-mono text-xs uppercase tracking-[0.18em] text-cyan-200/76">Canal directo</p>
                <p class="mt-4 text-lg font-semibold text-white">Enviar email</p>
                <p class="mt-2 text-sm leading-7 text-white/68">Ideal para procesos, propuestas, entrevistas o vacantes abiertas.</p>
                <span
                  data-email-feedback
                  class="copy-feedback pointer-events-none absolute right-4 top-4 rounded-full border border-cyan-300/20 bg-cyan-400/12 px-3 py-1 text-xs text-cyan-50 opacity-0"
                >
                  Abriendo Gmail
                </span>
              </button>

              <a
                href={portfolio.whatsappHref}
                target="_blank"
                rel="noopener noreferrer"
                class="rounded-[1.7rem] border border-white/10 bg-white/[0.04] p-5 transition duration-300 hover:border-cyan-300/30 hover:bg-white/[0.06]"
              >
                <p class="font-mono text-xs uppercase tracking-[0.18em] text-cyan-200/76">Respuesta rápida</p>
                <p class="mt-4 text-lg font-semibold text-white">Escribir por WhatsApp</p>
                <p class="mt-2 text-sm leading-7 text-white/68">Útil para primer contacto, coordinación o seguimiento ágil.</p>
              </a>

              <a
                href={portfolio.cvPath}
                download
                class="rounded-[1.7rem] border border-white/10 bg-white/[0.04] p-5 transition duration-300 hover:border-cyan-300/30 hover:bg-white/[0.06]"
              >
                <p class="font-mono text-xs uppercase tracking-[0.18em] text-cyan-200/76">Material de apoyo</p>
                <p class="mt-4 text-lg font-semibold text-white">Descargar CV en PDF</p>
                <p class="mt-2 text-sm leading-7 text-white/68">Versión actualizada y alineada con tu proceso de selección.</p>
              </a>

              <button
                type="button"
                data-copy-text={portfolio.email}
                class="relative rounded-[1.7rem] border border-white/10 bg-white/[0.04] p-5 text-left transition duration-300 hover:border-cyan-300/30 hover:bg-white/[0.06]"
              >
                <p class="font-mono text-xs uppercase tracking-[0.18em] text-cyan-200/76">Utilidad rápida</p>
                <p class="mt-4 text-lg font-semibold text-white">Copiar email</p>
                <p class="mt-2 text-sm leading-7 text-white/68">Para compartir mi contacto al instante sin cambiar de pestaña.</p>
                <span
                  data-copy-feedback
                  class="copy-feedback pointer-events-none absolute right-4 top-4 rounded-full border border-emerald-300/20 bg-emerald-400/12 px-3 py-1 text-xs text-emerald-100 opacity-0"
                >
                  Email copiado
                </span>
              </button>
            </div>
          </div>
        </article>
      </div>
    </section>
  </main>
</Layout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const header = document.getElementById("site-header");
    const navLinks = Array.from(document.querySelectorAll("[data-nav-link]"));
    const scrollLinks = Array.from(document.querySelectorAll("[data-scroll-link]"));
    const revealNodes = Array.from(document.querySelectorAll("[data-reveal]"));
    const copyButtons = Array.from(
      document.querySelectorAll("[data-copy-text]:not([data-email-action])"),
    );
    const emailActionButtons = Array.from(document.querySelectorAll("[data-email-action]"));
    const sectionIds = ["value", "experience", "projects", "contact"];
    const sections = sectionIds
      .map((id) => document.getElementById(id))
      .filter(Boolean);

    const updateHeaderState = () => {
      if (!header) {
        return;
      }

      header.classList.toggle("is-scrolled", window.scrollY > 24);
    };

    updateHeaderState();
    window.addEventListener("scroll", updateHeaderState, { passive: true });

    scrollLinks.forEach((link) => {
      link.addEventListener("click", (event) => {
        const href = link.getAttribute("href");
        if (!href || !href.startsWith("#")) {
          return;
        }

        const target = document.querySelector(href);
        if (!target) {
          return;
        }

        event.preventDefault();
        const offset = window.innerWidth >= 768 ? 92 : 40;
        const targetPosition = target.getBoundingClientRect().top + window.scrollY - offset;

        window.scrollTo({
          top: targetPosition,
          behavior: "smooth",
        });
      });
    });

    if (sections.length) {
      const sectionObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) {
              return;
            }

            const activeId = `#${entry.target.id}`;
            navLinks.forEach((link) => {
              const isActive = link.getAttribute("href") === activeId;
              link.classList.toggle("is-active", isActive);
              if (isActive) {
                link.setAttribute("aria-current", "true");
              } else {
                link.removeAttribute("aria-current");
              }
            });
          });
        },
        {
          rootMargin: "-35% 0px -50% 0px",
          threshold: 0.01,
        },
      );

      sections.forEach((section) => sectionObserver.observe(section));
    }

    if (revealNodes.length) {
      const revealObserver = new IntersectionObserver(
        (entries, observer) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) {
              return;
            }

            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          });
        },
        {
          rootMargin: "0px 0px -12% 0px",
          threshold: 0.14,
        },
      );

      revealNodes.forEach((node) => revealObserver.observe(node));
    }

    copyButtons.forEach((button) => {
      button.addEventListener("click", async () => {
        const text = button.getAttribute("data-copy-text");
        if (!text) {
          return;
        }

        try {
          await navigator.clipboard.writeText(text);
          const feedback = button.querySelector("[data-copy-feedback]");

          if (feedback) {
            feedback.classList.remove("opacity-0");
            feedback.classList.add("opacity-100");

            window.setTimeout(() => {
              feedback.classList.remove("opacity-100");
              feedback.classList.add("opacity-0");
            }, 1800);
          }
        } catch (error) {
          console.error("No se pudo copiar el email.", error);
        }
      });
    });

    emailActionButtons.forEach((button) => {
      button.addEventListener("click", async () => {
        const emailTo = button.getAttribute("data-email-to");
        if (!emailTo) {
          return;
        }

        const gmailComposeUrl = `https://mail.google.com/mail/?view=cm&fs=1&to=${encodeURIComponent(emailTo)}`;
        const feedback = button.querySelector("[data-email-feedback]");
        if (feedback) {
          feedback.classList.remove("opacity-0");
          feedback.classList.add("opacity-100");

          window.setTimeout(() => {
            feedback.classList.remove("opacity-100");
            feedback.classList.add("opacity-0");
          }, 1800);
        }

        window.open(gmailComposeUrl, "_blank", "noopener,noreferrer");
      });
    });
  });
</script>
