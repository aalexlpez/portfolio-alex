---
import { portfolio } from "../data/portfolio";

const navItems = portfolio.navigation;
---

<header id="site-header" class="pointer-events-none fixed inset-x-0 top-0 z-50 px-4 pt-4">
  <div
    class="pointer-events-auto mx-auto hidden max-w-6xl items-center justify-between rounded-full border border-white/10 bg-[rgba(8,16,29,0.62)] px-3 py-3 shadow-[0_12px_40px_rgba(3,8,20,0.38)] backdrop-blur-xl transition-all duration-500 md:flex"
  >
    <a
      href="#top"
      data-scroll-link
      class="flex h-11 w-11 items-center justify-center rounded-full border border-white/10 bg-white/5 font-mono text-sm font-semibold text-white transition duration-300 hover:border-cyan-300/40 hover:text-cyan-100"
    >
      {portfolio.initials}
    </a>

    <nav class="flex items-center gap-1">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            data-scroll-link
            data-nav-link
            class="rounded-full px-4 py-2 text-sm text-white/70 transition duration-300 hover:bg-white/6 hover:text-white"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <a
      href={portfolio.cvPath}
      download
      class="inline-flex items-center gap-2 rounded-full border border-emerald-300/25 bg-emerald-400/10 px-4 py-2 text-sm font-semibold text-emerald-100 transition duration-300 hover:border-emerald-200/50 hover:bg-emerald-300/16"
    >
      CV PDF
    </a>
  </div>

  <nav
    class="pointer-events-auto fixed bottom-4 left-4 right-4 z-50 mx-auto flex max-w-md items-center justify-between rounded-[1.6rem] border border-white/10 bg-[rgba(8,16,29,0.82)] px-3 py-3 shadow-[0_18px_40px_rgba(3,8,20,0.42)] backdrop-blur-xl md:hidden"
  >
    <a
      href="#value"
      data-scroll-link
      data-nav-link
      class="rounded-2xl px-3 py-2 text-center text-xs text-white/70 transition duration-300 hover:bg-white/6 hover:text-white"
    >
      Enfoque
    </a>
    <a
      href="#experience"
      data-scroll-link
      data-nav-link
      class="rounded-2xl px-3 py-2 text-center text-xs text-white/70 transition duration-300 hover:bg-white/6 hover:text-white"
    >
      Experiencia
    </a>
    <a
      href="#projects"
      data-scroll-link
      data-nav-link
      class="rounded-2xl px-3 py-2 text-center text-xs text-white/70 transition duration-300 hover:bg-white/6 hover:text-white"
    >
      Proyectos
    </a>
    <a
      href="#contact"
      data-scroll-link
      data-nav-link
      class="rounded-2xl px-3 py-2 text-center text-xs text-white/70 transition duration-300 hover:bg-white/6 hover:text-white"
    >
      Contacto
    </a>
  </nav>
</header>
